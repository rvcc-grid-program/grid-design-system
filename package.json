{
  "name": "grid-design-system",
  "private": true,
  "type": "module",
  "description": "GRID program design system — Console tokens + course-content components, with the wiki→Canvas build pipeline",
  "bin": {
    "grid-preview": "pipeline/preview-build.js",
    "grid-canvas": "pipeline/canvas-build.js"
  },
  "exports": {
    "./markdown": "./pipeline/markdown.js",
    "./enhance": "./pipeline/enhance.js",
    "./templates": "./pipeline/templates.js",
    "./config": "./pipeline/config.js",
    "./css/*": "./css/*"
  },
  "scripts": {
    "contrast": "node scripts/contrast.js",
    "preview": "node pipeline/preview-build.js",
    "canvas": "node pipeline/canvas-build.js",
    "site": "node pipeline/preview-build.js docs/index.md && cp specimen/specimen.html specimen/specimen.canvas.html docs/"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "gray-matter": "^4.0.3",
    "juice": "^12.1.0",
    "markdown-it": "^14.2.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^5.0.0",
    "markdown-it-bracketed-spans": "^1.0.1",
    "markdown-it-container": "^4.0.0"
  },
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed"
}
